# Get this from your Neon project dashboard (neon.tech) -> Connection Details
# Use the "pooled connection" string for DATABASE_URL and the direct one for DIRECT_URL
DATABASE_URL="postgresql://user:password@ep-example-12345.us-east-2.aws.neon.tech/sugarland?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-example-12345.us-east-2.aws.neon.tech/sugarland?sslmode=require"

# Any long random string. Generate one with: openssl rand -base64 32
JWT_SECRET="change-this-to-a-long-random-secret"

# The password the bakery owner will use to log into /admin
# NOTE: Admin login credentials are no longer read from here.
# They're hardcoded directly in app/api/admin/login/route.ts — edit that
# file to change the owner's email/password.
